{
    "name": "jdz/pdfbuilder",
    "type": "library",
    "description": "Build a PDF with TCPDF and FPDI",
    "keywords": [
        "JDZ",
        "utilities",
        "pdf"
    ],
    "homepage": "https://jdz.joffreydemetz.com/pdfBuilder/",
    "license": "MIT",
    "authors": [
        {
            "name": "Joffrey Demetz",
            "email": "joffrey.demetz@gmail.com",
            "homepage": "https://joffreydemetz.com",
            "role": "Lead"
        }
    ],
    "require": {
        "php": ">=8.1",
        "tecnickcom/tcpdf": "^6.3",
        "setasign/fpdi": "^2.6",
        "setasign/fpdi_pdf-parser": "^2.1",
        "symfony/yaml": "^7.2",
        "jdz/data": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "JDZ\\Pdf\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JDZ\\Pdf\\Tests\\": "tests"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://www.setasign.com/downloads/"
        }
    ]
}